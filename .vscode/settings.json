{
    "workbench.colorCustomizations": {
        "activityBar.activeBackground": "#000055",
        "activityBar.background": "#000055",
        "activityBar.foreground": "#e7e7e7",
        "activityBar.inactiveForeground": "#e7e7e799",
        "activityBarBadge.background": "#9f0000",
        "activityBarBadge.foreground": "#e7e7e7",
        "commandCenter.border": "#e7e7e799",
        "sash.hoverBorder": "#000055",
        "statusBar.background": "#000022",
        "statusBar.foreground": "#e7e7e7",
        "statusBarItem.hoverBackground": "#000055",
        "statusBarItem.remoteBackground": "#000022",
        "statusBarItem.remoteForeground": "#e7e7e7",
        "titleBar.activeBackground": "#000022",
        "titleBar.activeForeground": "#e7e7e7",
        "titleBar.inactiveBackground": "#00002299",
        "titleBar.inactiveForeground": "#e7e7e799"
    },
    "peacock.color": "#000022",
    "typescript.tsdk": "01-Doraemon/node_modules/typescript/lib",

    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.expand": false,
    "explorer.fileNesting.patterns": {
        "*.config.ts":   "${capture}.config.js, ${capture}.config.mjs",
        "vite.config.*": ".env, .env.*, tsconfig.json, tsconfig.*.json, eslint.config.*",
        "package.json":  "package-lock.json, .npmrc, .nvmrc, .node-version",
        "World.ts":      "scene.config.json, city.config.json, camera.config.json",
        "BuildingLab.ts": "wall.config.json, roof.config.json, door.config.json, windows.config.json, shopfront.config.json",
        "index.html":    "style.css, env.d.ts, main.ts"
    }
}