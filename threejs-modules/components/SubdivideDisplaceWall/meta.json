{
  "name": "SubdivideDisplaceWall",
  "category": "components",
  "version": "1.0.0",
  "description": "Tường gạch bằng subdivide plane + vertex displace — 1 mặt liền, đẩy đỉnh theo pattern gạch (gạch lồi, vữa lõm). So sánh với InstancedBrickWall (box instanced).",
  "tags": ["brick", "wall", "displacement", "vertex-displace", "subdivide", "heightmap", "lod", "architecture"],
  "complexity": "medium",
  "performance-cost": "medium",
  "performance": "1 mesh, 1 draw call. Triangle = segX·segY·2 (chỉnh qua subdivPerBrick → LOD dễ). Bậc gạch làm tròn mềm (đỉnh dùng chung). Muốn bậc sắc như box → chia mịn → tris cao. Hợp height-map (Megascans) sau.",
  "three-version": ">=0.174",
  "status": "experimental",
  "dependencies": ["three"],
  "props": [
    { "name": "width",          "type": "number", "default": "—",     "description": "Bề rộng tường (m, bắt buộc)" },
    { "name": "height",         "type": "number", "default": "—",     "description": "Chiều cao tường (m, bắt buộc)" },
    { "name": "depth",          "type": "number", "default": "0.1",   "description": "Bề dày nền sau (m)" },
    { "name": "brickL",         "type": "number", "default": "0.215", "description": "Dài mặt lộ viên (m)" },
    { "name": "brickH",         "type": "number", "default": "0.065", "description": "Cao mặt lộ viên (m)" },
    { "name": "joint",          "type": "number", "default": "0.01",  "description": "Bề rộng mạch vữa (m)" },
    { "name": "brickProtrude",  "type": "number", "default": "0.012", "description": "Gạch lồi khỏi vữa (m)" },
    { "name": "subdivPerBrick", "type": "number", "default": "3",     "description": "Số chia lưới / 1 viên mỗi trục — cao = bậc sắc + nhiều tris" },
    { "name": "brickColor",     "type": "THREE.ColorRepresentation", "default": "0xb86042", "description": "Màu gạch" },
    { "name": "mortarColor",    "type": "THREE.ColorRepresentation", "default": "0xc7c4be", "description": "Màu vữa" },
    { "name": "colorVariation", "type": "number", "default": "0.12",  "description": "Jitter sáng/tối từng viên [0-1]" }
  ],
  "usage": "const w = new SubdivideDisplaceWall({ width: 8, height: 3 }); scene.add(w.getGroup())"
}
